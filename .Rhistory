# --------------------------------------------------------- #
# VMA(3):
model_time <- make_vma3(p)
model_freq <- spec_prec_true(model="VMA", B=model_time$B, r=3, Sigma=model_time$Sigma, n=n)
Theta_star <- model_freq$th[,,(j+1)]
X <- sim_ts(model="VMA", Sigma=model_time$Sigma, B=model_time$B, r=3, n=n)
# --------------------------------------------------------- #
# # VARMA(2,2):
# model_time <- make_varma22(p)
