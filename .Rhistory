Spec <- spec_inv_freq(Z = Z,
Frequencies = w_j,
lambda = lambda,
Kernel = Modified_Bartlett,
M = M1,
M_corr = 1)
Stat_bench <- max_de_part_coh_H_0(Z=Z,
spec = Spec$spec,
Kernel = Modified_Bartlett,
M = M1,
DEMEAN = TRUE,
Delta_0 = 0,
FourierFrequencies_h = w_j)
Test_bench <- FDR_power(Est=((Stat_bench$TX_chi*n/M1) >= qchisq(1-alpha,2)),
Truth=(Theta_star!=0))
Test_pop
Test_plug
Test_HAC
Test_bench
