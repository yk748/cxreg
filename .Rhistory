#             q=2, r=2, n=n)
# --------------------------------------------------------- #
# Proposed method:
dft <- dft_all(X)
fhat <- fhat_at(dft, j, m)
D_sqrt_inv <- diag(sqrt(1/diag(fhat)))
est_cglasso <- cglasso(S=fhat, type="II", nobs=n,
D=D_sqrt_inv, lambda=sqrt(log(p)/bw))
# est_cglasso <- cglasso(S=fhat, type="I", nobs=n,
#                        D=D_sqrt_inv, lambda=sqrt(log(p)/bw))
Theta_hat <- est_cglasso$Theta_list[[1]]
Theta_tilde <- 2*Theta_hat - Theta_hat %*% fhat %*% Theta_hat
var_pop_dcmp <- var_pop(Theta=Theta_star)
var_plug_est <- var_plug(Theta=Theta_hat, X=X, j=j, m=m)
var_plug_est <- var_plug(Theta=Theta_hat, dft=dft, j, n, m)
var_plug_dcmp <- var_re_im(var_plug$V, var_std$PV)
var_plug_dcmp <- var_re_im(var_plug_est$V, var_std$PV)
var_plug_dcmp <- var_re_im(var_plug_est$V, var_plug_est$PV)
var_plug_dcmp
var_HAC_est <- var_hac(Theta=Theta_hat, dft=dft, j, n, m)
var_HAC_dcmp <- var_re_im(var_HAC_est$V, var_HAC_est$PV)
cr_pop <- stat_cmp(Est=Theta_tilde, Truth=Theta_star, var_dcmp=var_pop_dcmp, bw=bw, alpha=alpha)
cr_std <- stat_cmp(Est=Theta_tilde, Truth=Theta_star, var_dcmp=var_plug_est, bw=bw, alpha=alpha)
cr_plug <- stat_cmp(Est=Theta_tilde, Truth=Theta_star, var_dcmp=var_plug_est, bw=bw, alpha=alpha)
cr_plug <- stat_cmp(Est=Theta_tilde, Truth=Theta_star, var_dcmp=var_plug_dcmp, bw=bw, alpha=alpha)
cr_HAC <- stat_cmp(Est=Theta_tilde, Truth=Theta_star, var_dcmp=var_HAC_dcmp, bw=bw, alpha=alpha)
null_pop <- stat_cmp(Est=Theta_tilde, Truth=matrix(0,p,p), var_dcmp=var_pop_dcmp, bw=bw, alpha=alpha)$Chi_sq
null_plug <- stat_cmp(Est=Theta_tilde, Truth=matrix(0,p,p), var_dcmp=var_plug_dcmp, bw=bw, alpha=alpha)$Chi_sq
null_HAC <- stat_cmp(Est=Theta_tilde, Truth=matrix(0,p,p), var_dcmp=var_HAC_dcmp, bw=bw, alpha=alpha)$Chi_sq
Test_pop <- FDR_power(Est=(null_pop >= qchisq(1-alpha,2)), Truth=(Theta_star!=0))
Test_plug <- FDR_power(Est=(null_plug >= qchisq(1-alpha,2)), Truth=(Theta_star!=0))
Test_HAC <- FDR_power(Est=(null_HAC >= qchisq(1-alpha,2)), Truth=(Theta_star!=0))
