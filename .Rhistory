dft <- dft_all(X)
fhat <- fhat_at(dft, j, m)
D_sqrt_inv <- diag(sqrt(1/diag(fhat)))
est_cglasso <- cglasso(S=fhat, type="II", nobs=n,
D=D_sqrt_inv, lambda=sqrt(log(p)/bw))
# est_cglasso <- cglasso(S=fhat, type="I", nobs=n,
#                        D=D_sqrt_inv, lambda=sqrt(log(p)/bw))
Theta_hat <- est_cglasso$Theta_list[[1]]
Theta_tilde <- 2*Theta_hat - Theta_hat %*% fhat %*% Theta_hat
var_pop_dcmp <- var_pop(Theta=Theta_star)
var_std <- var_stand(Theta=Theta_hat, X=X, j=j, m=m)
var_pop_dcmp <- var_pop(Theta=Theta_star)
var_plug <- var_plug(Theta=Theta_hat, X=X, j=j, m=m)
var_pop_dcmp
var_plug
rm(list = ls())
