vma_terms <- vma_terms + as.numeric(B[[j]] %*% E[t - j, ])
}
}
X[t, ] <- var_terms + vma_terms
}
}
return(X[(burn + 1):total_n, , drop=FALSE])
}
#############################################################
# Compute variances
#############################################################
# Compute variance (population)
var_pop <- function(Theta=NULL){
p <- dim(Theta)[1]
Vre <- Vim <- Cov <- matrix(NA,p,p)
dg <- diag(Theta)
for (a in 1:p){
for (b in 1:p){
Vre[a,b] <- Re(0.5*(dg[a]*dg[b] + Re(Theta[a,b])^2))
Vim[a,b] <- Re(0.5*(dg[a]*dg[b] - Re(Theta[a,b])^2))
Cov[a,b] <- 0.5*Im(Theta[a,b])^2
}
}
return(list(Vre = Vre, Vim = Vim, Cov = Cov))
}
# ----------------------------------------------------------#
# Decompose the variance to real-imaginary covariances by using pseudovariance
var_re_im <- function(V, PV) {
Vre <- 0.5 * Re(V + PV)
Vim <- 0.5 * Re(V - PV)
Cov <- 0.5 * Im(PV)
return(list(Vre = Vre, Vim = Vim, Cov = Cov))
}
# ----------------------------------------------------------#
# Compute variance (plug-in)
var_plug <- function(Theta=NULL, dft=NULL, j, n, m) {
p  <- nrow(Theta)
bw <- 2*m + 1
h  <- -m:m
# window frequencies (0-based)
k_grid <- (j+h) %% n
M_list <- vector("list", bw)
for (k in seq_len(bw)) {
f_k <- fhat_at(dft, k_grid[k], m)
M_list[[k]] <- Theta %*% f_k %*% Theta
}
M_mat <- matrix(0+0i, bw, p*p)
D_mat <- matrix(0+0i, bw, p)
for (k in seq_len(bw)) {
Mk <- M_list[[k]]
M_mat[k, ] <- as.vector(Mk)
D_mat[k, ] <- diag(Mk)
}
# Fixed part of variance:
W_A <- diag(1, bw)
V_A <- (t(D_mat) %*% D_mat) / bw
# Float part of variance:
W_B <- (outer(k_grid, k_grid, "+") %% n == 0) * 1
Z_B <- W_B %*% M_mat
V_B_vec <- colSums(M_mat * Z_B)/bw
V_B <- matrix(V_B_vec, p, p)
# Float part of pseudovariance:
PV_A_vec <- colSums(M_mat * M_mat)/bw
PV_A <- matrix(PV_A_vec, p, p)
# Fixed part of pseudovariance:
PV_B <- (t(D_mat) %*% (W_B %*% D_mat))/bw
return(list(V = V_A + V_B, PV = PV_A + PV_B,
k_grid = k_grid, W_B = W_B))
}
# ----------------------------------------------------------#
# Compute HAC variance estimators
var_hac <- function(Theta, dft=NULL, j, n, m) {
p  <- nrow(Theta)
bw <- 2*m + 1
h  <- -m:m
W <- diag(1, bw)
k_grid <- (j + h) %% n
W <- W + (outer(k_grid, k_grid, "+") %% n == 0) * 1
# Compute cached y-matrix:
Y_mat <- matrix(0+0i, bw, p*p)
for (r in seq_len(bw)) {
dr_k <- dft[((k_grid[r] %% n) + 1), , drop=TRUE]
# dr_k <- dft[fixm(k_grid[r], n), , drop=TRUE]
Yr_vec <- as.vector(t(Conj(dr_k)) %*% Theta)
fr_k <- fhat_at(dft, k_grid[r], m)
Br_k <- Theta %*% fr_k %*% Theta
Yr <- outer(Conj(Yr_vec), Yr_vec, "*") - Br_k
Y_mat[r, ] <- as.vector(Yr)
}
# sigma_vec[c] = sum_r Ymat[r,c] * (W %*% Conj(Ymat))[r,c]
Z_sig <- W %*% Conj(Y_mat)          # bw x p^2
sigma_vec <- colSums(Y_mat * Z_sig) / bw
# delta_vec[c] = sum_r Ymat[r,c] * (W %*% Ymat)[r,c]
Z_del <- W %*% Y_mat
delta_vec <- colSums(Y_mat * Z_del) / bw
return(list(
V = matrix(sigma_vec, p, p),
PV = matrix(delta_vec, p, p),
k_grid    = k_grid,
W         = W
))
}
#############################################################
# Evaluation functions:
#############################################################
# Z statistics for real/imaginary and chi-squared statistics:
stat_cmp <- function(Est,Truth,var_dcmp,bw,alpha,eps=1e-8) {
p <- dim(Truth)[1]
Re_diff <- Re(Est) - Re(Truth)
Im_diff <- Im(Est) - Im(Truth)
Z_re <- Z_im <- Chi_sq <- wing_re <- wing_im <- area <- matrix(NA,p,p)
for (a in 1:p){
for (b in 1:p){
if (var_dcmp$Vre[a,b] == 0){
# Z statistics:
Z_re[a,b] <- Z_im[a,b] <- wing_re[a,b] <- wing_im[a,b] <- Chi_sq[a,b] <- area[a,b] <- 0
}else if (a == b | var_dcmp$Vim[a,b] == 0){
# Z statistics:
Z_re[a,b] <- Re_diff[a,b]/sqrt(var_dcmp$Vre[a,b]/bw)
Z_im[a,b] <- 0
# CI:
wing_re[a,b] <- qnorm(1-alpha/2)*sqrt(var_dcmp$Vre[a,b]/bw)
wing_im[a,b] <- 0
# Chi-squared statistics:
Chi_sq[a,b] <- Z_re[a,b]^2
# area:
area[a,b] <- pi*qchisq(1-alpha,2)/bw*sqrt(var_dcmp$Vre[a,b])
}else{
# Z statistics:
Z_re[a,b] <- Re_diff[a,b]/sqrt(var_dcmp$Vre[a,b]/bw)
Z_im[a,b] <- Im_diff[a,b]/sqrt(var_dcmp$Vim[a,b]/bw)
# CI:
wing_re[a,b] <- qnorm(1-alpha/2)*sqrt(var_dcmp$Vre[a,b]/bw)
wing_im[a,b] <- qnorm(1-alpha/2)*sqrt(var_dcmp$Vim[a,b]/bw)
# Chi-squared statistics:
vec <- c(Re_diff[a,b],Im_diff[a,b])
cov <- matrix(c(var_dcmp$Vre[a,b],var_dcmp$Cov[a,b],
var_dcmp$Cov[a,b],var_dcmp$Vim[a,b]),2,2)
eig <- eigen(cov)$values
if (all(eig >= eps)){
Chi_sq[a,b] <- bw * t(vec) %*% solve(cov) %*% vec
# area:
area[a,b] <- pi*qchisq(1-alpha,2)/bw*sqrt(det(cov))
}else{
Chi_sq[a,b] <- bw * Re_diff[a,b]^2/var_dcmp$Vre[a,b]
# area:
area[a,b] <- pi*qchisq(1-alpha,2)/bw*sqrt(var_dcmp$Vre[a,b])
}
}
}
}
return(
list(Chi_sq=Chi_sq, area=area,
Z_re=Z_re, wing_re=wing_re,
Z_im=Z_im, wing_im=wing_im)
)
}
# ----------------------------------------------------------#
# Compute FDR and power (simple)
FDR_power <- function(Est,Truth){
p <- dim(Truth)[1]
idx <- upper.tri(Truth, diag=TRUE)
true_vec <- Truth[idx]
est_vec  <- Est[idx]
TP <- sum(est_vec != 0 & true_vec != 0)  # true positives
FP <- sum(est_vec != 0 & true_vec == 0)  # false positives
FN <- sum(est_vec == 0 & true_vec != 0)  # false negatives
FDR <- ifelse((TP + FP) == 0, 0, FP / (TP + FP))
Power <- TP / sum(true_vec == 1)
return(list(FDR=FDR,Power=Power))
}
